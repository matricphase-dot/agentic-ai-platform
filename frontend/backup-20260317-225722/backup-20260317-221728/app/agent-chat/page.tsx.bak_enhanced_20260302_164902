'use client';

import { useState, useEffect } from 'react';
import { useAuth } from '@/hooks/useAuth';
import { api } from '@/lib/api';
import { Send, Bot, Plus, RefreshCw, Loader2 } from 'lucide-react';

interface Agent {
  id: string;
  name: string;
  description: string | null;
  capabilities: string | null;
  systemPrompt: string | null;
  ollamaEndpoint: string | null;
  ownerId: string;
}

export default function AgentChatPage() {
  const { user } = useAuth();
  const [agents, setAgents] = useState<Agent[]>([]);
  const [selectedAgent, setSelectedAgent] = useState<Agent | null>(null);
  const [messages, setMessages] = useState<any[]>([]);
  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);
  const [sending, setSending] = useState(false);
  const [refreshing, setRefreshing] = useState(false);
  const [showCreateForm, setShowCreateForm] = useState(false);
  const [creating, setCreating] = useState(false);
  const [error, setError] = useState<string | null>(null);

  // New agent form fields
  const [newName, setNewName] = useState('');
  const [newDesc, setNewDesc] = useState('');
  const [newCaps, setNewCaps] = useState('ollama:llama2');
  const [newSystemPrompt, setNewSystemPrompt] = useState('');
  const [newEndpoint, setNewEndpoint] = useState('');
  const [useRemote, setUseRemote] = useState(false);

  // Fetch agents
  const fetchAgents = async () => {
    setRefreshing(true);
    try {
      const res = await api.get('/agents');
      setAgents(res.data);
    } catch (err) {
      console.error(err);
      setError('Failed to load agents');
    } finally {
      setRefreshing(false);
    }
  };

  useEffect(() => {
    if (user) fetchAgents();
  }, [user]);

  // Create agent
  const createAgent = async () => {
    if (!newName.trim()) return;
    setCreating(true);
    try {
      const payload: any = {
        name: newName,
        description: newDesc,
        capabilities: newCaps,
        systemPrompt: newSystemPrompt,
      };
      if (useRemote && newEndpoint.trim()) {
        payload.ollamaEndpoint = newEndpoint;
      }
      await api.post('/agents', payload);
      setNewName('');
      setNewDesc('');
      setNewCaps('ollama:llama2');
      setNewSystemPrompt('');
      setNewEndpoint('');
      setUseRemote(false);
      setShowCreateForm(false);
      fetchAgents();
    } catch (err) {
      console.error(err);
      setError('Failed to create agent');
    } finally {
      setCreating(false);
    }
  };

  // Fetch messages for selected agent
  const fetchMessages = async (agentId: string) => {
    try {
      const res = await api.get(`/messages/inbox/${agentId}`);
      setMessages(res.data);
    } catch (err) {
      console.error(err);
    }
  };

  useEffect(() => {
    if (selectedAgent) {
      fetchMessages(selectedAgent.id);
      const interval = setInterval(() => fetchMessages(selectedAgent.id), 3000);
      return () => clearInterval(interval);
    }
  }, [selectedAgent]);

  // Send message
  const sendMessage = async () => {
    if (!selectedAgent || !input.trim()) return;
    setSending(true);
    try {
      const myAgent = agents.find(a => a.ownerId === user?.id);
      if (!myAgent) {
        alert('You need to create your own agent first.');
        return;
      }
      await api.post('/messages', {
        senderId: myAgent.id,
        receiverId: selectedAgent.id,
        content: { text: input }
      });
      setInput('');
      fetchMessages(selectedAgent.id);
    } catch (err) {
      console.error(err);
    } finally {
      setSending(false);
    }
  };

  if (!user) return <div className="p-8">Please log in</div>;

  return (
    <div className="min-h-screen bg-gray-50 p-8">
      <div className="max-w-4xl mx-auto">
        <h1 className="text-3xl font-bold mb-6">Agent Communication</h1>

        {error && (
          <div className="mb-4 p-3 bg-red-100 text-red-700 rounded">
            {error}
          </div>
        )}

        <div className="flex gap-3 mb-6">
          <button
            onClick={() => setShowCreateForm(!showCreateForm)}
            className="px-4 py-2 bg-green-600 text-white rounded flex items-center gap-2"
          >
            <Plus className="w-5 h-5" />
            Create Agent
          </button>
          <button
            onClick={fetchAgents}
            disabled={refreshing}
            className="px-4 py-2 bg-blue-600 text-white rounded flex items-center gap-2"
          >
            <RefreshCw className={`w-5 h-5 ${refreshing ? 'animate-spin' : ''}`} />
            Refresh
          </button>
        </div>

        {showCreateForm && (
          <div className="bg-white rounded-lg shadow p-6 mb-6">
            <h2 className="text-xl font-semibold mb-4">Create New Agent</h2>
            <div className="space-y-4">
              <div>
                <label className="block text-sm font-medium mb-1">Name *</label>
                <input
                  type="text"
                  value={newName}
                  onChange={(e) => setNewName(e.target.value)}
                  className="w-full p-2 border rounded"
                />
              </div>
              <div>
                <label className="block text-sm font-medium mb-1">Description</label>
                <input
                  type="text"
                  value={newDesc}
                  onChange={(e) => setNewDesc(e.target.value)}
                  className="w-full p-2 border rounded"
                />
              </div>
              <div>
                <label className="block text-sm font-medium mb-1">Capabilities</label>
                <input
                  type="text"
                  value={newCaps}
                  onChange={(e) => setNewCaps(e.target.value)}
                  className="w-full p-2 border rounded"
                  placeholder="e.g., ollama:llama2, ollama:mistral"
                />
                <p className="text-xs text-gray-500 mt-1">
                  Use "ollama:modelname" to specify model.
                </p>
              </div>
              <div>
                <label className="block text-sm font-medium mb-1">System Prompt</label>
                <textarea
                  value={newSystemPrompt}
                  onChange={(e) => setNewSystemPrompt(e.target.value)}
                  className="w-full p-2 border rounded h-24"
                  placeholder="Optional instructions for the agent"
                />
              </div>
              <div className="flex items-center gap-2">
                <input
                  type="checkbox"
                  id="useRemote"
                  checked={useRemote}
                  onChange={(e) => setUseRemote(e.target.checked)}
                />
                <label htmlFor="useRemote">Use remote Ollama server</label>
              </div>
              {useRemote && (
                <div>
                  <label className="block text-sm font-medium mb-1">Remote Endpoint</label>
                  <input
                    type="text"
                    value={newEndpoint}
                    onChange={(e) => setNewEndpoint(e.target.value)}
                    className="w-full p-2 border rounded"
                    placeholder="http://your-server:11434"
                  />
                  <p className="text-xs text-gray-500 mt-1">
                    If left empty, local Ollama will be used.
                  </p>
                </div>
              )}
              <div className="flex gap-2">
                <button
                  onClick={createAgent}
                  disabled={creating}
                  className="px-4 py-2 bg-blue-600 text-white rounded flex items-center gap-2"
                >
                  {creating && <Loader2 className="w-5 h-5 animate-spin" />}
                  Create
                </button>
                <button
                  onClick={() => setShowCreateForm(false)}
                  className="px-4 py-2 bg-gray-300 text-gray-700 rounded"
                >
                  Cancel
                </button>
              </div>
            </div>
          </div>
        )}

        <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
          {/* Agent list */}
          <div className="bg-white rounded-lg shadow p-4">
            <h2 className="text-lg font-semibold mb-3 flex items-center gap-2">
              <Bot className="w-5 h-5" />
              Agents
            </h2>
            {agents.length === 0 ? (
              <p className="text-gray-500">No agents yet.</p>
            ) : (
              <div className="space-y-2">
                {agents.map((agent) => (
                  <button
                    key={agent.id}
                    onClick={() => setSelectedAgent(agent)}
                    className={`w-full text-left p-3 rounded flex items-center gap-2 ${
                      selectedAgent?.id === agent.id ? 'bg-blue-100' : 'hover:bg-gray-100'
                    }`}
                  >
                    <Bot className="w-5 h-5 text-gray-600" />
                    <div>
                      <div className="font-medium">{agent.name}</div>
                      {agent.ollamaEndpoint && (
                        <div className="text-xs text-gray-500">remote</div>
                      )}
                    </div>
                  </button>
                ))}
              </div>
            )}
          </div>

          {/* Chat area */}
          <div className="md:col-span-2 bg-white rounded-lg shadow p-4">
            {selectedAgent ? (
              <>
                <div className="border-b pb-2 mb-4">
                  <h3 className="text-lg font-semibold">{selectedAgent.name}</h3>
                  {selectedAgent.ollamaEndpoint && (
                    <p className="text-xs text-gray-500">Remote: {selectedAgent.ollamaEndpoint}</p>
                  )}
                </div>
                <div className="h-96 overflow-y-auto border rounded p-4 mb-4">
                  {messages.map((msg) => (
                    <div key={msg.id} className="mb-2">
                      <div className="bg-gray-100 p-2 rounded inline-block">
                        {JSON.parse(msg.content).text || msg.content}
                      </div>
                    </div>
                  ))}
                </div>
                <div className="flex gap-2">
                  <input
                    type="text"
                    value={input}
                    onChange={(e) => setInput(e.target.value)}
                    onKeyPress={(e) => e.key === 'Enter' && sendMessage()}
                    className="flex-1 p-2 border rounded"
                  />
                  <button
                    onClick={sendMessage}
                    disabled={sending}
                    className="px-4 py-2 bg-blue-600 text-white rounded"
                  >
                    <Send className="w-5 h-5" />
                  </button>
                </div>
              </>
            ) : (
              <p className="text-center text-gray-500">Select an agent</p>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}