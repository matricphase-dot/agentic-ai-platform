'use client';

import { useState, useEffect } from 'react';
import { useAuth } from '@/hooks/useAuth';
import { api } from '@/lib/api';
import { Send, Bot, User } from 'lucide-react';

interface Agent {
  id: string;
  name: string;
  description: string;
  capabilities: string;
}

interface Message {
  id: string;
  content: string;
  senderId: string;
  receiverId: string;
  createdAt: string;
  sender: { name: string };
}

export default function AgentChatPage() {
  const { user } = useAuth();
  const [agents, setAgents] = useState<Agent[]>([]);
  const [selectedAgent, setSelectedAgent] = useState<string>('');
  const [messages, setMessages] = useState<Message[]>([]);
  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);
  const [myAgent, setMyAgent] = useState<Agent | null>(null);

  useEffect(() => {
    if (!user) return;
    fetchAgents();
  }, [user]);

  const fetchAgents = async () => {
    try {
      const res = await api.get('/api/agents');
      setAgents(res.data);
      // Find an agent owned by the current user (you may need to create one first)
      // For demo, we'll just pick the first agent if none is found
    } catch (err) {
      console.error('Failed to fetch agents', err);
    }
  };

  const fetchMessages = async (agentId: string) => {
    try {
      const res = await api.get(`/api/messages/inbox/${agentId}`);
      setMessages(res.data);
    } catch (err) {
      console.error('Failed to fetch messages', err);
    }
  };

  const sendMessage = async () => {
    if (!selectedAgent || !input.trim()) return;
    setLoading(true);
    try {
      // Find an agent owned by the current user to send from
      // This assumes the user has created at least one agent
      const senderAgent = agents.find(a => a.ownerId === user?.id);
      if (!senderAgent) {
        alert('Please create an agent for yourself first (e.g., "MyAgent")');
        return;
      }

      const payload = {
        senderId: senderAgent.id,
        receiverId: selectedAgent,
        content: { text: input }
      };
      await api.post('/api/messages', payload);
      setInput('');
      // Refresh messages after a short delay
      setTimeout(() => fetchMessages(selectedAgent), 1000);
    } catch (err) {
      console.error('Failed to send message', err);
    } finally {
      setLoading(false);
    }
  };

  if (!user) return <div className="p-8">Please log in</div>;

  return (
    <div className="min-h-screen bg-gray-50 p-8">
      <div className="max-w-4xl mx-auto">
        <h1 className="text-3xl font-bold mb-6">Agent Communication</h1>

        <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
          {/* Agent List */}
          <div className="bg-white rounded-lg shadow p-4">
            <h2 className="text-xl font-semibold mb-4">Available Agents</h2>
            {agents.length === 0 ? (
              <p className="text-gray-500">No agents found. Create one first.</p>
            ) : (
              <ul className="space-y-2">
                {agents.map(agent => (
                  <li key={agent.id}>
                    <button
                      onClick={() => {
                        setSelectedAgent(agent.id);
                        fetchMessages(agent.id);
                      }}
                      className={`w-full text-left p-3 rounded flex items-center gap-2 ${
                        selectedAgent === agent.id ? 'bg-blue-100' : 'hover:bg-gray-100'
                      }`}
                    >
                      <Bot className="w-5 h-5 text-gray-600" />
                      <div>
                        <div className="font-medium">{agent.name}</div>
                        <div className="text-sm text-gray-500">{agent.description}</div>
                      </div>
                    </button>
                  </li>
                ))}
              </ul>
            )}
          </div>

          {/* Chat Area */}
          <div className="md:col-span-2 bg-white rounded-lg shadow p-4">
            {selectedAgent ? (
              <>
                <div className="h-96 overflow-y-auto border rounded p-4 mb-4">
                  {messages.map(msg => (
                    <div key={msg.id} className={`mb-4 ${msg.senderId === selectedAgent ? 'text-left' : 'text-right'}`}>
                      <div className={`inline-block p-3 rounded ${
                        msg.senderId === selectedAgent ? 'bg-gray-100' : 'bg-blue-100'
                      }`}>
                        <p className="text-sm">{JSON.parse(msg.content).text || msg.content}</p>
                        <p className="text-xs text-gray-500 mt-1">
                          {new Date(msg.createdAt).toLocaleTimeString()}
                        </p>
                      </div>
                    </div>
                  ))}
                </div>

                <div className="flex gap-2">
                  <input
                    type="text"
                    value={input}
                    onChange={(e) => setInput(e.target.value)}
                    onKeyPress={(e) => e.key === 'Enter' && sendMessage()}
                    className="flex-1 p-2 border rounded"
                    placeholder="Type a message..."
                  />
                  <button
                    onClick={sendMessage}
                    disabled={loading}
                    className="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 disabled:bg-blue-300"
                  >
                    <Send className="w-5 h-5" />
                  </button>
                </div>
              </>
            ) : (
              <p className="text-center text-gray-500">Select an agent to start chatting</p>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}