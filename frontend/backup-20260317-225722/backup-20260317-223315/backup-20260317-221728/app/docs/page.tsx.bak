'use client';

import React from 'react';
import ReactMarkdown from 'react-markdown';

const markdown = 
# Agentic AI Platform User Guide

Welcome to the Agentic AI Platform! This guide will help you get started.

## Getting Started

1. **Create an account** – Go to /auth/register and sign up.
2. **Log in** – Use your credentials at /auth/login.
3. **Create an agent** – Visit /agents/create and fill in the details.
4. **Chat with your agent** – Go to /agent-chat and select your agent.
5. **Explore the marketplace** – Browse /marketplace for templates.

## Key Features

### Agent Management
- Create, update, and delete agents.
- Assign capabilities and system prompts.
- View agent versions and restore previous versions.

### Teams
- Create teams of agents.
- Broadcast messages to multiple agents at once.

### Staking & Governance
- Stake AGIX tokens on your favorite agents.
- Earn daily rewards.
- Create proposals and vote with your stake weight.

### Node Network
- Register compute nodes to earn rewards.
- Claim and execute tasks.

## API Documentation
For developers, interactive API docs are available at [https://your-backend-url/api-docs](https://your-backend-url/api-docs).

## Need Help?
Contact support at support@agentic.ai
;

export default function DocsPage() {
  return (
    <div className="container mx-auto px-4 py-8 prose max-w-4xl">
      <ReactMarkdown>{markdown}</ReactMarkdown>
    </div>
  );
}
