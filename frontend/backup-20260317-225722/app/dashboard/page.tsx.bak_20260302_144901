"use client";

import { useEffect, useState } from "react";
import { useAuth } from "@/hooks/useAuth";
import { api } from "@/lib/api";
import StatsCard from "@/components/StatsCard";
import { 
  Users, 
  Coins, 
  FileText, 
  ShoppingCart,
  ArrowRight
} from "lucide-react";
import Link from "next/link";

export default function DashboardPage() {
  const { user } = useAuth();
  const [stats, setStats] = useState({
    agents: { total: 0, active: 0 },
    staking: { totalStaked: 0, rewards: 0 },
    proposals: { active: 0, total: 0 },
    marketplace: { listings: 0, downloads: 0 }
  });
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const fetchDashboardData = async () => {
      try {
        // Default fallback data
        const defaultStats = {
          agents: { total: 0, active: 0 },
          staking: { totalStaked: 0, rewards: 0 },
          proposals: { active: 0, total: 0 },
          marketplace: { listings: 0, downloads: 0 }
        };

        let combinedStats = { ...defaultStats };

        // Try each endpoint individually - if any fails, default remains
        try {
          const agentsRes = await api.get('/aiq/agents/stats');
          combinedStats.agents = agentsRes.data;
        } catch (e) {
          console.warn('Agents stats endpoint not available, using defaults');
        }

        try {
          const stakingRes = await api.get('/aiq/staking/stats');
          combinedStats.staking = stakingRes.data;
        } catch (e) {
          console.warn('Staking stats endpoint not available, using defaults');
        }

        try {
          const proposalsRes = await api.get('/aiq/proposals/stats');
          combinedStats.proposals = proposalsRes.data;
        } catch (e) {
          console.warn('Proposals stats endpoint not available, using defaults');
        }

        try {
          const marketplaceRes = await api.get('/aiq/marketplace/stats');
          combinedStats.marketplace = marketplaceRes.data;
        } catch (e) {
          console.warn('Marketplace stats endpoint not available, using defaults');
        }

        setStats(combinedStats);
      } catch (error) {
        console.error('Unexpected error loading dashboard', error);
      } finally {
        setLoading(false);
      }
    };

    fetchDashboardData();
  }, []);

  if (loading) {
    return (
      <div className="flex items-center justify-center min-h-screen">
        <div className="text-xl">Loading dashboard...</div>
      </div>
    );
  }

  return (
    <div className="p-6 space-y-6">
      <div className="flex justify-between items-center">
        <h1 className="text-3xl font-bold">Dashboard</h1>
        <div className="text-sm text-gray-600">
          Welcome back, {user?.email || 'User'}
        </div>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <StatsCard
          title="Agents"
          value={stats.agents.total}
          subtitle={`${stats.agents.active} active`}
          icon={<Users className="w-6 h-6" />}
          color="blue"
        />
        <StatsCard
          title="Staking"
          value={`${stats.staking.totalStaked} AGIX`}
          subtitle={`${stats.staking.rewards} rewards`}
          icon={<Coins className="w-6 h-6" />}
          color="green"
        />
        <StatsCard
          title="Proposals"
          value={stats.proposals.total}
          subtitle={`${stats.proposals.active} active`}
          icon={<FileText className="w-6 h-6" />}
          color="purple"
        />
        <StatsCard
          title="Marketplace"
          value={stats.marketplace.listings}
          subtitle={`${stats.marketplace.downloads} downloads`}
          icon={<ShoppingCart className="w-6 h-6" />}
          color="orange"
        />
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-8">
        <div className="bg-white rounded-lg shadow p-6">
          <h2 className="text-xl font-semibold mb-4">Quick Actions</h2>
          <div className="space-y-3">
            <Link href="/agent-chat" className="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100">
              <span>Chat with Agents</span>
              <ArrowRight className="w-4 h-4" />
            </Link>
            <Link href="/knowledge" className="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100">
              <span>Upload Documents</span>
              <ArrowRight className="w-4 h-4" />
            </Link>
            <Link href="/recorder" className="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100">
              <span>Record Screen</span>
              <ArrowRight className="w-4 h-4" />
            </Link>
          </div>
        </div>

        <div className="bg-white rounded-lg shadow p-6">
          <h2 className="text-xl font-semibold mb-4">Recent Activity</h2>
          <p className="text-gray-600">No recent activity</p>
        </div>
      </div>
    </div>
  );
}
