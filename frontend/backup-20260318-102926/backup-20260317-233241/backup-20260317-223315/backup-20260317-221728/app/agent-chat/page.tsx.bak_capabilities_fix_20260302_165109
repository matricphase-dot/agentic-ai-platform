"use client";

import { useEffect, useState } from "react";
import { useAuth } from "@/hooks/useAuth";
import { api } from "@/lib/api";
import { Bot, Send, User, Clock, Info, Zap, Code, BookOpen, Loader2 } from "lucide-react";

interface Agent {
  id: string;
  name: string;
  description: string;
  capabilities: string[];
  systemPrompt: string;
  createdAt: string;
}

interface Message {
  id: string;
  content: string;
  senderId: string;
  receiverId: string;
  createdAt: string;
  status: string;
}

export default function AgentChatPage() {
  const { user } = useAuth();
  const [agents, setAgents] = useState<Agent[]>([]);
  const [selectedAgent, setSelectedAgent] = useState<Agent | null>(null);
  const [messages, setMessages] = useState<Message[]>([]);
  const [newMessage, setNewMessage] = useState("");
  const [loadingAgents, setLoadingAgents] = useState(true);
  const [loadingMessages, setLoadingMessages] = useState(false);
  const [sending, setSending] = useState(false);
  const [showAgentDetails, setShowAgentDetails] = useState(false);

  useEffect(() => {
    fetchAgents();
  }, []);

  useEffect(() => {
    if (selectedAgent) {
      fetchMessages();
      // Poll for new messages every 3 seconds
      const interval = setInterval(fetchMessages, 3000);
      return () => clearInterval(interval);
    }
  }, [selectedAgent]);

  const fetchAgents = async () => {
    try {
      const response = await api.get('/agents');
      setAgents(response.data);
    } catch (error) {
      console.error('Failed to fetch agents:', error);
    } finally {
      setLoadingAgents(false);
    }
  };

  const fetchMessages = async () => {
    if (!selectedAgent) return;
    try {
      setLoadingMessages(true);
      const response = await api.get('/messages/inbox');
      // Filter messages related to selected agent
      const agentMessages = response.data.filter(
        (msg: Message) => msg.senderId === selectedAgent.id || msg.receiverId === selectedAgent.id
      );
      setMessages(agentMessages.sort((a: Message, b: Message) => 
        new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime()
      ));
    } catch (error) {
      console.error('Failed to fetch messages:', error);
    } finally {
      setLoadingMessages(false);
    }
  };

  const sendMessage = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!selectedAgent || !newMessage.trim() || sending) return;

    setSending(true);
    try {
      const response = await api.post('/messages', {
        agentId: selectedAgent.id,
        content: newMessage
      });
      setMessages(prev => [...prev, response.data]);
      setNewMessage("");
    } catch (error) {
      console.error('Failed to send message:', error);
    } finally {
      setSending(false);
    }
  };

  const formatTime = (dateString: string) => {
    return new Date(dateString).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  };

  const getAgentIcon = (capabilities: string[]) => {
    if (capabilities.includes('echo')) return <Zap className="w-5 h-5" />;
    if (capabilities.includes('rag')) return <BookOpen className="w-5 h-5" />;
    return <Code className="w-5 h-5" />;
  };

  if (loadingAgents) {
    return (
      <div className="flex items-center justify-center min-h-screen">
        <Loader2 className="w-8 h-8 animate-spin text-blue-500" />
      </div>
    );
  }

  return (
    <div className="flex h-screen bg-gray-50">
      {/* Agents Sidebar */}
      <div className="w-80 border-r bg-white flex flex-col">
        <div className="p-4 border-b">
          <h2 className="text-xl font-semibold">Agents</h2>
          <p className="text-sm text-gray-500">Select an agent to chat</p>
        </div>
        <div className="flex-1 overflow-y-auto p-2">
          {agents.length === 0 ? (
            <div className="text-center text-gray-500 mt-8">
              <Bot className="w-12 h-12 mx-auto mb-3 text-gray-400" />
              <p>No agents yet</p>
              <p className="text-sm">Create one from the Marketplace</p>
            </div>
          ) : (
            agents.map(agent => (
              <button
                key={agent.id}
                onClick={() => setSelectedAgent(agent)}
                className={`w-full text-left p-3 rounded-lg mb-2 transition-colors ${
                  selectedAgent?.id === agent.id
                    ? 'bg-blue-50 border-blue-200 border'
                    : 'hover:bg-gray-100'
                }`}
              >
                <div className="flex items-center gap-3">
                  <div className="p-2 bg-blue-100 rounded-lg text-blue-600">
                    {getAgentIcon(agent.capabilities)}
                  </div>
                  <div className="flex-1 min-w-0">
                    <div className="font-medium truncate">{agent.name}</div>
                    <div className="text-xs text-gray-500 truncate">
                      {agent.capabilities.join(' • ')}
                    </div>
                  </div>
                </div>
              </button>
            ))
          )}
        </div>
      </div>

      {/* Chat Area */}
      <div className="flex-1 flex flex-col">
        {selectedAgent ? (
          <>
            {/* Chat Header */}
            <div className="bg-white border-b p-4 flex items-center justify-between">
              <div className="flex items-center gap-3">
                <div className="p-2 bg-blue-100 rounded-lg text-blue-600">
                  {getAgentIcon(selectedAgent.capabilities)}
                </div>
                <div>
                  <h2 className="text-xl font-semibold">{selectedAgent.name}</h2>
                  <p className="text-sm text-gray-500">{selectedAgent.description}</p>
                </div>
              </div>
              <button
                onClick={() => setShowAgentDetails(!showAgentDetails)}
                className="p-2 hover:bg-gray-100 rounded-lg"
                title="Agent Details"
              >
                <Info className="w-5 h-5 text-gray-600" />
              </button>
            </div>

            {/* Agent Details Panel (conditional) */}
            {showAgentDetails && (
              <div className="bg-gray-50 border-b p-4 text-sm">
                <h3 className="font-semibold mb-2">System Prompt</h3>
                <p className="bg-white p-3 rounded border whitespace-pre-wrap">
                  {selectedAgent.systemPrompt}
                </p>
                <h3 className="font-semibold mt-3 mb-2">Capabilities</h3>
                <div className="flex flex-wrap gap-2">
                  {selectedAgent.capabilities.map(cap => (
                    <span key={cap} className="bg-blue-100 text-blue-800 px-2 py-1 rounded-full text-xs">
                      {cap}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {/* Messages */}
            <div className="flex-1 overflow-y-auto p-4 space-y-4">
              {loadingMessages ? (
                <div className="flex justify-center">
                  <Loader2 className="w-6 h-6 animate-spin text-blue-500" />
                </div>
              ) : messages.length === 0 ? (
                <div className="text-center text-gray-500 mt-8">
                  <Bot className="w-12 h-12 mx-auto mb-3 text-gray-400" />
                  <p>No messages yet</p>
                  <p className="text-sm">Start the conversation!</p>
                </div>
              ) : (
                messages.map(msg => (
                  <div
                    key={msg.id}
                    className={`flex ${msg.senderId === user?.id ? 'justify-end' : 'justify-start'}`}
                  >
                    <div
                      className={`max-w-[70%] rounded-lg p-3 ${
                        msg.senderId === user?.id
                          ? 'bg-blue-500 text-white'
                          : 'bg-white border'
                      }`}
                    >
                      <div className="flex items-center gap-2 mb-1 text-xs opacity-75">
                        {msg.senderId === user?.id ? (
                          <User className="w-3 h-3" />
                        ) : (
                          <Bot className="w-3 h-3" />
                        )}
                        <span>{formatTime(msg.createdAt)}</span>
                      </div>
                      <div className="whitespace-pre-wrap">{msg.content}</div>
                    </div>
                  </div>
                ))
              )}
            </div>

            {/* Message Input */}
            <form onSubmit={sendMessage} className="bg-white border-t p-4">
              <div className="flex gap-2">
                <input
                  type="text"
                  value={newMessage}
                  onChange={(e) => setNewMessage(e.target.value)}
                  placeholder="Type your message..."
                  className="flex-1 border rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                  disabled={sending}
                />
                <button
                  type="submit"
                  disabled={!newMessage.trim() || sending}
                  className="bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600 disabled:bg-blue-300 transition-colors flex items-center gap-2"
                >
                  {sending ? <Loader2 className="w-4 h-4 animate-spin" /> : <Send className="w-4 h-4" />}
                  Send
                </button>
              </div>
            </form>
          </>
        ) : (
          <div className="flex-1 flex items-center justify-center text-gray-500">
            <div className="text-center">
              <Bot className="w-16 h-16 mx-auto mb-4 text-gray-300" />
              <h3 className="text-xl font-semibold mb-2">Select an Agent</h3>
              <p>Choose an agent from the sidebar to start chatting</p>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
