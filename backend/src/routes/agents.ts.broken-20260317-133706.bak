import { Router } from 'express';
import { prisma } from '../lib/prisma';
import { authenticate } from '../middleware/auth';
import * as crypto from 'crypto';

const router = Router();

// Get all agents for current user
router.get('/', authenticate, async (req, res) => {
  try {
    const agents = await (prisma as any).agents.findMany({
      where: { owner_id: (req as any).user.id },
      orderBy: { createdAt: 'desc' }
          },\n      owner: { connect: { id: req.user.id } }\n    });res.json(agents);
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Failed to fetch agents'       },\n      owner: { connect: { id: req.user.id } }\n    });}
      },\n      owner: { connect: { id: req.user.id } }\n    });// Get single agent
router.get('/:id', authenticate, async (req, res) => {
  try {
    const { id } = req.params;
    const agent = await (prisma as any).agents.findUnique({
      where: { id }
          },\n      owner: { connect: { id: req.user.id } }\n    });if (!agent) return res.status(404).json({ error: 'Agent not found'       },\n      owner: { connect: { id: req.user.id } }\n    });if (agent.owner_id !== (req as any).user.id) {
      return res.status(403).json({ error: 'Not authorized'       },\n      owner: { connect: { id: req.user.id } }\n    });}
    res.json(agent);
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Failed to fetch agent'       },\n      owner: { connect: { id: req.user.id } }\n    });}
      },\n      owner: { connect: { id: req.user.id } }\n    });// Create a new agent
router.post('/', authenticate, async (req, res) => {
  try {
    const { name, description, capabilities, systemPrompt, modelProvider, modelName, status } = req.body;
    const agent = await (prisma as any).agents.create({
      data: {
        id: crypto.randomUUID(),
        owner_id: (req as any).user.id,
        name,
        description,
        capabilities: capabilities ? String(capabilities) : null,
        system_prompt: systemPrompt,
        model_provider: modelProvider || 'ollama-local',
        model_name: modelName || 'llama2',
        status: status || 'active',
        agentType: 'SUPPORT',
        reputation_score: 1000,
        hourly_rate: 50,
        success_rate: 0.85,
        total_value_created: 0,
        tasks_completed: 0,
        specialties: [],
        configuration: {},
        revenue_share: 0,
        total_earnings: 0,
        createdAt: new Date(),
        }
          },\n      owner: { connect: { id: req.user.id } }\n    });res.status(201).json(agent);
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Failed to create agent'       },\n      owner: { connect: { id: req.user.id } }\n    });}
      },\n      owner: { connect: { id: req.user.id } }\n    });// Update an agent
router.put('/:id', authenticate, async (req, res) => {
  try {
    const { id } = req.params;
    const agent = await (prisma as any).agents.findUnique({ where: { id }       },\n      owner: { connect: { id: req.user.id } }\n    });if (!agent) return res.status(404).json({ error: 'Agent not found'       },\n      owner: { connect: { id: req.user.id } }\n    });if (agent.owner_id !== (req as any).user.id) {
      return res.status(403).json({ error: 'Not authorized'       },\n      owner: { connect: { id: req.user.id } }\n    });}
    const updated = await (prisma as any).agents.update({
      where: { id },
      data: req.body
          },\n      owner: { connect: { id: req.user.id } }\n    });res.json(updated);
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Failed to update agent'       },\n      owner: { connect: { id: req.user.id } }\n    });}
      },\n      owner: { connect: { id: req.user.id } }\n    });// Delete an agent
router.delete('/:id', authenticate, async (req, res) => {
  try {
    const { id } = req.params;
    const agent = await (prisma as any).agents.findUnique({ where: { id }       },\n      owner: { connect: { id: req.user.id } }\n    });if (!agent) return res.status(404).json({ error: 'Agent not found'       },\n      owner: { connect: { id: req.user.id } }\n    });if (agent.owner_id !== (req as any).user.id) {
      return res.status(403).json({ error: 'Not authorized'       },\n      owner: { connect: { id: req.user.id } }\n    });}
    await (prisma as any).agents.delete({ where: { id }       },\n      owner: { connect: { id: req.user.id } }\n    });res.status(204).send();
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Failed to delete agent'       },\n      owner: { connect: { id: req.user.id } }\n    });}
      },\n      owner: { connect: { id: req.user.id } }\n    });export default router;



