datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model users {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  password_hash   String
  balance         Float    @default(0)
  token_balance   Float    @default(0)
  reputation_score Float   @default(0)
  role            String   @default("user")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  agents        agents[]
  businesses    businesses[]
  stakes        stakes[]
  proposals     proposals[]
  votes         votes[]
  notifications notifications[]
}

model agents {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  agent_type         String
  status             String   @default("active")
  configuration      Json?
  capabilities       Json?
  hourly_rate        Float    @default(0)
  success_rate       Float    @default(0)
  total_value_created Float   @default(0)
  tasks_completed    Int      @default(0)
  reputation_score   Float    @default(0)
  owner_id           String
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  owner        users    @relation(fields: [owner_id], references: [id])
  deployments  deployments[]
  stakes       stakes[]
}

model businesses {
  id                       String   @id @default(cuid())
  name                     String
  description              String?
  business_type            String
  configuration            Json?
  owner_id                 String
  revenue                  Float    @default(0)
  profit                   Float    @default(0)
  monthly_recurring_revenue Float   @default(0)
  status                   String   @default("active")
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  owner         users           @relation(fields: [owner_id], references: [id])
  business_agents business_agents[]
  contracts     contracts[]
}

model business_agents {
  id          String   @id @default(cuid())
  business_id String
  agent_id    String
  role        String?
  assigned_at DateTime @default(now())

  business businesses @relation(fields: [business_id], references: [id])
  agent    agents     @relation(fields: [agent_id], references: [id])

  @@unique([business_id, agent_id])
}

model contracts {
  id          String   @id @default(cuid())
  business_id String
  agent_id    String
  terms       Json?
  status      String   @default("ACTIVE")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  business businesses @relation(fields: [business_id], references: [id])
  agent    agents     @relation(fields: [agent_id], references: [id])
}

model stakes {
  id          String   @id @default(cuid())
  staker_id   String
  agent_id    String?
  amount      Float
  status      String   @default("active")
  lock_until  DateTime?
  unstaked_at DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  staker users   @relation(fields: [staker_id], references: [id])
  agent  agents? @relation(fields: [agent_id], references: [id])
}

model proposals {
  id          String   @id @default(cuid())
  title       String
  description String
  proposer_id String
  status      String   @default("active")
  voting_ends DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  proposer users  @relation(fields: [proposer_id], references: [id])
  votes    votes[]
}

model votes {
  id          String   @id @default(cuid())
  proposal_id String
  voter_id    String
  support     Boolean
  weight      Float
  created_at  DateTime @default(now())

  proposal proposals @relation(fields: [proposal_id], references: [id])
  voter    users     @relation(fields: [voter_id], references: [id])

  @@unique([proposal_id, voter_id])
}

model notifications {
  id         String   @id @default(cuid())
  user_id    String
  type       String
  title      String
  message    String?
  read       Boolean  @default(false)
  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])
}

model deployments {
  id           String   @id @default(cuid())
  agent_id     String
  platform_id  String
  external_id  String?
  config       Json?
  status       String   @default("pending")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  agent                 agents               @relation(fields: [agent_id], references: [id])
  platform_connections  platform_connections @relation(fields: [platform_id], references: [id])
  deployment_logs       deployment_logs[]
  revenue_logs          revenue_logs[]
}

model deployment_logs {
  id            String   @id @default(cuid())
  deployment_id String
  message       String
  level         String   @default("info")
  created_at    DateTime @default(now())

  deployment deployments @relation(fields: [deployment_id], references: [id])
}

model revenue_logs {
  id            String   @id @default(cuid())
  deployment_id String
  amount        Float
  description   String?
  created_at    DateTime @default(now())

  deployment deployments @relation(fields: [deployment_id], references: [id])
}

model platform_connections {
  id          String   @id @default(cuid())
  user_id     String
  platform    String
  credentials Json
  status      String   @default("active")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user        users        @relation(fields: [user_id], references: [id])
  deployments deployments[]
}

model agent_blueprints {
  id           String   @id @default(cuid())
  name         String
  description  String?
  agent_type   String
  configuration Json
  specialties  Json?
  price        Float
  royalty_rate Float
  status       String   @default("active")
  creator_id   String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  creator    users       @relation(fields: [creator_id], references: [id])
  franchises franchises[]
  clones     agent_clones[]
}

model agent_clones {
  id              String   @id @default(cuid())
  blueprint_id    String
  agent_id        String
  buyer_id        String
  purchase_price  Float
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  blueprint agent_blueprints @relation(fields: [blueprint_id], references: [id])
  agent     agents           @relation(fields: [agent_id], references: [id])
  buyer     users            @relation(fields: [buyer_id], references: [id])
}

model franchises {
  id                String   @id @default(cuid())
  blueprint_id      String
  owner_id          String
  agent_id          String?
  status            String   @default("active")
  purchase_price    Float
  total_royalty_paid Float   @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  blueprint       agent_blueprints @relation(fields: [blueprint_id], references: [id])
  owner           users            @relation(fields: [owner_id], references: [id])
  agent           agents?          @relation(fields: [agent_id], references: [id])
  royalty_payments royalty_payments[]
}

model royalty_payments {
  id            String   @id @default(cuid())
  franchise_id  String
  amount        Float
  period_start  DateTime
  period_end    DateTime
  status        String   @default("pending")
  paid_at       DateTime?
  created_at    DateTime @default(now())

  franchise franchises @relation(fields: [franchise_id], references: [id])
}

model quantum_keys {
  id         String   @id @default(cuid())
  agent_id   String   @unique
  public_key String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  agent agents @relation(fields: [agent_id], references: [id])
}

model agent_messages {
  id            String   @id @default(cuid())
  from_agent_id String
  to_agent_id   String
  content       String
  signature     String
  status        String   @default("pending")
  delivered_at  DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  from_agent agents @relation("sent", fields: [from_agent_id], references: [id])
  to_agent   agents @relation("received", fields: [to_agent_id], references: [id])
}

model consensus_rounds {
  id           String   @id @default(cuid())
  round_number Int      @unique
  status       String   @default("active")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  votes consensus_votes[]
}

model consensus_votes {
  id         String   @id @default(cuid())
  round_id   String
  agent_id   String
  vote       Boolean
  weight     Float
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  round consensus_rounds @relation(fields: [round_id], references: [id])
  agent agents           @relation(fields: [agent_id], references: [id])
}

model token_transactions {
  id          String   @id @default(cuid())
  from_user_id String?
  to_user_id   String?
  amount       Float
  type         String
  description  String?
  status       String   @default("completed")
  created_at   DateTime @default(now())

  from_user users? @relation("sent", fields: [from_user_id], references: [id])
  to_user   users? @relation("received", fields: [to_user_id], references: [id])
}

model service_listings {
  id            String   @id @default(cuid())
  agent_id      String
  title         String
  description   String?
  service_type  String
  pricing_type  String
  price         Float
  currency      String   @default("USD")
  status        String   @default("active")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  agent agents                @relation(fields: [agent_id], references: [id])
  orders service_orders[]
}

model service_orders {
  id           String   @id @default(cuid())
  listing_id   String
  buyer_id     String
  description  String?
  total_amount Float
  status       String   @default("pending")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  listing service_listings @relation(fields: [listing_id], references: [id])
  buyer   users            @relation(fields: [buyer_id], references: [id])
  logs    service_execution_logs[]
}

model service_execution_logs {
  id           String   @id @default(cuid())
  order_id     String
  description  String?
  hours_worked Float?
  amount       Float?
  status       String   @default("pending")
  completed_at DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  order service_orders @relation(fields: [order_id], references: [id])
}

model node_tasks {
  id           String   @id @default(cuid())
  node_id      String
  agent_id     String?
  type         String
  payload      Json?
  status       String   @default("pending")
  reward       Float?
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  node nodes @relation(fields: [node_id], references: [id])
}

model node_rewards {
  id           String   @id @default(cuid())
  node_id      String
  amount       Float
  reason       String?
  period_start DateTime
  period_end   DateTime
  paid_at      DateTime?
  created_at   DateTime @default(now())

  node nodes @relation(fields: [node_id], references: [id])
}

model nodes {
  id         String   @id @default(cuid())
  owner_id   String
  name       String
  endpoint   String?
  status     String   @default("offline")
  last_ping  DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  owner      users        @relation(fields: [owner_id], references: [id])
  node_tasks node_tasks[]
  node_rewards node_rewards[]
}

model nations {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  citizens    citizens[]
  proposals   nation_proposals[]
}

model citizens {
  id         String   @id @default(cuid())
  nation_id  String
  user_id    String
  joined_at  DateTime @default(now())

  nation nations @relation(fields: [nation_id], references: [id])
  user   users   @relation(fields: [user_id], references: [id])

  @@unique([nation_id, user_id])
}

model nation_proposals {
  id          String   @id @default(cuid())
  nation_id   String
  proposer_id String
  title       String
  description String
  status      String   @default("active")
  voting_ends DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  nation nations      @relation(fields: [nation_id], references: [id])
  proposer citizens   @relation(fields: [proposer_id], references: [id])
  votes    nation_votes[]
}

model nation_votes {
  id          String   @id @default(cuid())
  proposal_id String
  voter_id    String
  support     Boolean
  weight      Float
  created_at  DateTime @default(now())

  proposal nation_proposals @relation(fields: [proposal_id], references: [id])
  voter    citizens         @relation(fields: [voter_id], references: [id])

  @@unique([proposal_id, voter_id])
}

model startups {
  id          String   @id @default(cuid())
  name        String
  description String?
  website     String?
  stage       String
  founder_id  String
  token_amount Float   @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  founder        users                 @relation(fields: [founder_id], references: [id])
  proposals      investment_proposals[]
}

model investment_proposals {
  id           String   @id @default(cuid())
  startup_id   String
  proposer_id  String
  title        String
  description  String
  ask_amount   Float
  equity       Float?
  status       String   @default("pending")
  created_at   DateTime @default(now())
  reviewed_at  DateTime?
  funded_at    DateTime?

  startup startups         @relation(fields: [startup_id], references: [id])
  proposer users           @relation(fields: [proposer_id], references: [id])
  reports  due_diligence_reports[]
  investments investments[]
}

model due_diligence_reports {
  id            String   @id @default(cuid())
  proposal_id   String
  agent_id      String?
  score         Float
  summary       String
  details       Json?
  risks         Json?
  recommendation String
  created_at    DateTime @default(now())

  proposal investment_proposals @relation(fields: [proposal_id], references: [id])
}

model investments {
  id          String   @id @default(cuid())
  proposal_id String
  investor_id String
  amount      Float
  equity      Float?
  created_at  DateTime @default(now())

  proposal investment_proposals @relation(fields: [proposal_id], references: [id])
  investor users                @relation(fields: [investor_id], references: [id])
}

model pricing_rules {
  id          String   @id @default(cuid())
  agent_type  String
  base_price  Float
  demand      Float
  multiplier  Float
  updated_at  DateTime @updatedAt
}

model system_diagnostics {
  id           String   @id @default(cuid())
  metric       String
  value        Float
  threshold    Float
  action_taken String
  created_at   DateTime @default(now())
}

model integration_templates {
  id            String   @id @default(cuid())
  api_name      String
  api_docs_url  String
  generated_code String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model integration_logs {
  id            String   @id @default(cuid())
  agent_id      String
  connection_id String
  action        String
  request       Json?
  response      Json?
  status        String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  agent      agents              @relation(fields: [agent_id], references: [id])
  connection user_connections    @relation(fields: [connection_id], references: [id])
}

model user_connections {
  id           String   @id @default(cuid())
  user_id      String
  connector_id String
  credentials  Json?
  status       String   @default("active")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user          users                 @relation(fields: [user_id], references: [id])
  connector     connectors            @relation(fields: [connector_id], references: [id])
  bindings      agent_service_bindings[]
  integration_logs integration_logs[]
}

model connectors {
  id          String   @id @default(cuid())
  name        String
  description String?
  logo_url    String?
  auth_type   String
  auth_config Json?
  base_url    String?
  endpoints   Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user_connections user_connections[]
}

model agent_service_bindings {
  id            String   @id @default(cuid())
  agent_id      String
  connection_id String
  permissions   Json?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  agent      agents           @relation(fields: [agent_id], references: [id])
  connection user_connections @relation(fields: [connection_id], references: [id])
}

model derivative_contracts {
  id               String   @id @default(cuid())
  contract_type    String
  agent_id         String
  seller_id        String
  buyer_id         String?
  strike_price     Float
  quantity         Int
  expiry_date      DateTime
  settlement_metric String
  premium          Float?
  status           String   @default("active")
  payout           Float?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  agent   agents  @relation(fields: [agent_id], references: [id])
  seller  users   @relation("seller", fields: [seller_id], references: [id])
  buyer   users?  @relation("buyer", fields: [buyer_id], references: [id])
  positions positions[]
}

model positions {
  id          String   @id @default(cuid())
  user_id     String
  contract_id String
  side        String
  quantity    Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user     users               @relation(fields: [user_id], references: [id])
  contract derivative_contracts @relation(fields: [contract_id], references: [id])
}

model settlement_logs {
  id           String   @id @default(cuid())
  contract_id  String
  agent_metric Float
  payout       Float
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  contract derivative_contracts @relation(fields: [contract_id], references: [id])
}

model competitor_insights {
  id          String   @id @default(cuid())
  competitor  String
  feature     String
  description String
  created_at  DateTime @default(now())
}

model learning_rounds {
  id           String   @id @default(cuid())
  round_number Int      @unique
  global_model Json?
  status       String   @default("active")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  contributions contributions[]
}

model contributions {
  id           String   @id @default(cuid())
  round_id     String
  agent_id     String
  model_delta  Json?
  quality      Float?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  round        learning_rounds @relation(fields: [round_id], references: [id])
  agent        agents          @relation(fields: [agent_id], references: [id])
}

model recommendations {
  id          String   @id @default(cuid())
  user_id     String
  type        String
  title       String
  description String?
  priority    Int
  metadata    Json?
  created_at  DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])
}
