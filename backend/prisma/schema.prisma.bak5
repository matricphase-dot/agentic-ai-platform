model Unknownmodel {
  @@map("UnknownModel")
  datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
  capabilities Json?
}
  capabilities Json?
}

model Unknownmodel {
  @@map("UnknownModel")
  generator client {
  provider = "prisma-client-js"
  capabilities Json?
}
  capabilities Json?
}
model Unknownmodel {
  @@map("UnknownModel")
  generator client {
  provider = "prisma-client-js"
  capabilities Json?
}
  capabilities Json?
}


model Agent {
  @@map("Agent")
  id String                  @id @default(cuid())
  name String
  description String?
  agentType String
  status String                  @default("IDLE")
  reputationScore Int                     @default(1000)
  hourlyRate Float                   @default(50)
  successRate Float                   @default(0.85)
  totalValueCreated Float                   @default(0)
  totalEarnings Float                   @default(0)
  configuration Json?
  tasksCompleted Int                     @default(0)
  specialties Json?
  ownerId String
  @id @default(cuid())createdAt                                                  DateTime                @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtUser                                                       User                    @relation(fields: [ownerId], references: [id])
  AgentClone AgentClone[]
  AgentEarning AgentEarning[]
  agenthireagreementAgenthireagreementHiredagentidtoagent AgentHireAgreement[]    @relation("AgentHireAgreement_hiredAgentIdToAgent")
  agenthireagreementAgenthireagreementHiringagentidtoagent AgentHireAgreement[]    @relation("AgentHireAgreement_hiringAgentIdToAgent")
  AgentServiceBinding AgentServiceBinding[]
  AgentServiceListing AgentServiceListing[]
  BusinessAgent BusinessAgent[]
  Contract Contract[]
  Contribution Contribution[]
  DerivativeContract DerivativeContract[]
  IntegrationLog IntegrationLog[]
  Transaction Transaction[]
  deployments deployments[]
  dueDiligenceReports due_diligence_reports[]
  nodeTasks node_tasks[]
  stakes stakes[]

  @@index([agentType])
  @@index([ownerId])
  @@index([reputationScore])
  capabilities Json?
  capabilities Json?
  capabilities Json?
}
  capabilities Json?
}

model Agentblueprint {
  @@map("AgentBlueprint")
  id String       @id @default(cuid())
  name String
  description String?
  agentType String
  configuration Json?
  specialties Json?
  price Float        @default(0)
  royaltyRate Float        @default(0.1)
  ownerId String
  @id @default(cuid())isActive      Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtUser          User         @relation(fields: [ownerId], references: [id])
  AgentClone AgentClone[]
  capabilities Json?
}
  capabilities Json?
}

model Agentclone {
  @@map("AgentClone")
  id String         @id @default(cuid())
  blueprintId String
  @id @default(cuid())agentId        String
  @id @default(cuid())buyerId        String
  @id @default(cuid())purchasePrice  Float
  createdAt DateTime       @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtUser           User           @relation(fields: [buyerId], references: [id])
  Agent Agent          @relation(fields: [agentId], references: [id])
  AgentBlueprint AgentBlueprint @relation(fields: [blueprintId], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Agentearning {
  @@map("AgentEarning")
  id String   @id @default(cuid())
  agentId String
  @id @default(cuid())amount    Float
  source String
  sourceId String?
  createdAt DateTime @default(now())
  Agent Agent    @relation(fields: [agentId], references: [id])

  @@index([agentId])
  capabilities Json?
}
  capabilities Json?
}

model Agenthireagreement {
  @@map("AgentHireAgreement")
  id String                @id @default(cuid())
  listingId String
  @id @default(cuid())hiringAgentId                                 String
  @id @default(cuid())hiredAgentId                                  String
  @id @default(cuid())terms                                         Json?
  totalValue Float
  revenueShare Float?
  status String                @default("PENDING")
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtagentAgenthireagreementHiredagentidtoagent  Agent                 @relation("AgentHireAgreement_hiredAgentIdToAgent", fields: [hiredAgentId], references: [id])
  agentAgenthireagreementHiringagentidtoagent Agent                 @relation("AgentHireAgreement_hiringAgentIdToAgent", fields: [hiringAgentId], references: [id])
  AgentServiceListing AgentServiceListing   @relation(fields: [listingId], references: [id])
  ServiceExecutionLog ServiceExecutionLog[]
  capabilities Json?
}
  capabilities Json?
}

model Agentservicebinding {
  @@map("AgentServiceBinding")
  id String         @id @default(cuid())
  agentId String
  @id @default(cuid())connectionId   String
  @id @default(cuid())permissions    Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtUserConnection UserConnection @relation(fields: [connectionId], references: [id])
  Agent Agent          @relation(fields: [agentId], references: [id])

  @@unique([agentId, connectionId])
  capabilities Json?
}
  capabilities Json?
}

model Agentservicelisting {
  @@map("AgentServiceListing")
  id String               @id @default(cuid())
  agentId String
  @id @default(cuid())title              String
  description String?
  serviceType String
  pricingType String
  price Float
  currency String               @default("USD")
  status String               @default("ACTIVE")
  createdAt DateTime             @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtAgentHireAgreement AgentHireAgreement[]
  Agent Agent                @relation(fields: [agentId], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Busines {
  @@map("Business")
  id String          @id @default(cuid())
  name String
  description String?
  businessType String
  status String          @default("ACTIVE")
  revenue Float           @default(0)
  profit Float           @default(0)
  monthlyRecurringRevenue Float           @default(0)
  configuration Json?
  ownerId String
  @id @default(cuid())createdAt               DateTime        @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtUser                    User            @relation(fields: [ownerId], references: [id])
  BusinessAgent BusinessAgent[]
  Contract Contract[]
  Transaction Transaction[]

  @@index([ownerId])
  capabilities Json?
}
  capabilities Json?
}

model Businessagent {
  @@map("BusinessAgent")
  id String   @id @default(cuid())
  businessId String
  @id @default(cuid())agentId    String
  @id @default(cuid())role       String?
  assignedAt DateTime @default(now())
  Agent Agent    @relation(fields: [agentId], references: [id])
  Business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, agentId])
  capabilities Json?
}
  capabilities Json?
}

model Businesstemplate {
  @@map("BusinessTemplate")
  id String   @id @default(cuid())
  name String   @unique
  description String?
  industry String
  configuration Json?
  thumbnail String?
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
@updatedAt}

  model CompetitorInsight {
  id String   @id @default(cuid())
  competitor String
  feature String
  description String
  createdAt DateTime @default(now())
  capabilities Json?
}
  capabilities Json?
}

model Connector {
  @@map("Connector")
  id String           @id @default(cuid())
  name String           @unique
  description String?
  logoUrl String?
  authType String
  authConfig Json?
  baseUrl String
  endpoints Json?
  isBuiltIn Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtUserConnection UserConnection[]
  capabilities Json?
}
  capabilities Json?
}

model Contract {
  @@map("Contract")
  id String    @id @default(cuid())
  businessId String
  @id @default(cuid())agentId      String
  @id @default(cuid())terms        Json?
  status String    @default("ACTIVE")
  valueCreated Float     @default(0)
  agentCut Float     @default(0.15)
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  Agent Agent     @relation(fields: [agentId], references: [id])
  Business Business  @relation(fields: [businessId], references: [id])

  @@index([businessId, agentId])
  capabilities Json?
}
  capabilities Json?
}

model Contribution {
  @@map("Contribution")
  id String        @id @default(cuid())
  roundId String
  @id @default(cuid())agentId       String
  @id @default(cuid())modelDelta    Json?
  quality Float?
  reward Float?
  submittedAt DateTime      @default(now())
  createdAt DateTime      @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtAgent         Agent         @relation(fields: [agentId], references: [id])
  LearningRound LearningRound @relation(fields: [roundId], references: [id])

  @@unique([roundId, agentId])
  capabilities Json?
}
  capabilities Json?
}

model Derivativecontract {
  @@map("DerivativeContract")
  id String          @id @default(cuid())
  contractType String
  agentId String
  @id @default(cuid())sellerId                               String
  @id @default(cuid())buyerId                                String?
  strikePrice Float
  quantity Int
  expiryDate DateTime
  premium Float?
  settlementMetric String
  status String          @default("OPEN")
  settlementValue Float?
  payout Float?
  createdAt DateTime        @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtuserDerivativecontractBuyeridtouser  User?           @relation("DerivativeContract_buyerIdToUser", fields: [buyerId], references: [id])
  userDerivativecontractSelleridtouser User            @relation("DerivativeContract_sellerIdToUser", fields: [sellerId], references: [id])
  Agent Agent           @relation(fields: [agentId], references: [id])
  Position Position[]
  SettlementLog SettlementLog[]
  capabilities Json?
}
  capabilities Json?
}

model Integrationlog {
  @@map("IntegrationLog")
  id String          @id @default(cuid())
  agentId String?
  connectionId String?
  action String
  request Json?
  response Json?
  status String
  error String?
  createdAt DateTime        @default(now())
  UserConnection UserConnection? @relation(fields: [connectionId], references: [id])
  Agent Agent?          @relation(fields: [agentId], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Integrationtemplate {
  @@map("IntegrationTemplate")
  id String   @id @default(cuid())
  apiName String   @unique
  apiDocsUrl String
  generatedCode String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
@updatedAt}

  model LearningRound {
  id String         @id @default(cuid())
  roundNumber Int            @unique
  globalModel Json?
  startedAt DateTime       @default(now())
  completedAt DateTime?
  status String         @default("active")
  contributionCount Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtContribution      Contribution[]
  capabilities Json?
}
  capabilities Json?
}

model Notification {
  @@map("Notification")
  id String   @id @default(cuid())
  userId String
  @id @default(cuid())type      String
  title String
  message String
  read Boolean  @default(false)
  data Json?
  createdAt DateTime @default(now())
  User User     @relation(fields: [userId], references: [id])

  @@index([userId, read])
  capabilities Json?
}
  capabilities Json?
}

model Position {
  @@map("Position")
  id String             @id @default(cuid())
  userId String
  @id @default(cuid())contractId         String
  @id @default(cuid())side               String
  quantity Int
  createdAt DateTime           @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtDerivativeContract DerivativeContract @relation(fields: [contractId], references: [id])
  User User               @relation(fields: [userId], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Pricingrule {
  @@map("PricingRule")
  id String   @id @default(cuid())
  agentType String   @unique
  basePrice Float
  demand Float
  multiplier Float
  updatedAt DateTime @updatedAt
@updatedAt}

  model Recommendation {
  id String    @id @default(cuid())
  userId String
  @id @default(cuid())type        String
  title String
  description String
  priority Int       @default(1)
  metadata Json?
  isRead Boolean   @default(false)
  isActioned Boolean   @default(false)
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  User User      @relation(fields: [userId], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Serviceexecutionlog {
  @@map("ServiceExecutionLog")
  id String             @id @default(cuid())
  agreementId String
  @id @default(cuid())description        String?
  hoursWorked Float?
  amount Float?
  status String             @default("PENDING")
  completedAt DateTime?
  createdAt DateTime           @default(now())
  AgentHireAgreement AgentHireAgreement @relation(fields: [agreementId], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Settlementlog {
  @@map("SettlementLog")
  id String             @id @default(cuid())
  contractId String
  @id @default(cuid())agentMetric        Float
  payout Float
  settledAt DateTime           @default(now())
  DerivativeContract DerivativeContract @relation(fields: [contractId], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Systemdiagnostic {
  @@map("SystemDiagnostic")
  id String   @id @default(cuid())
  timestamp DateTime @default(now())
  metric String
  value Float
  threshold Float
  actionTaken String?
  capabilities Json?
}
  capabilities Json?
}

model Transaction {
  @@map("Transaction")
  id String    @id @default(cuid())
  type String
  amount Float
  currency String    @default("USD")
  fromUserId String?
  toUserId String?
  agentId String?
  businessId String?
  description String?
  metadata Json?
  status String    @default("PENDING")
  createdAt DateTime  @default(now())
  completedAt DateTime?
  Business Business? @relation(fields: [businessId], references: [id])
  Agent Agent?    @relation(fields: [agentId], references: [id])
  userTransactionTouseridtouser User?     @relation("Transaction_toUserIdToUser", fields: [toUserId], references: [id])
  userTransactionFromuseridtouser User?     @relation("Transaction_fromUserIdToUser", fields: [fromUserId], references: [id])

  @@index([fromUserId, toUserId])
  capabilities Json?
}
  capabilities Json?
}

model User {
  @@map("User")
  id String                 @id @default(cuid())
  email String                 @unique
  passwordHash String
  name String?
  avatar String?
  balance Float                  @default(0)
  tokenBalance Float                  @default(0)
  reputationScore Int                    @default(1000)
  role String                 @default("USER")
  createdAt DateTime               @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtAgent                                                    Agent[]
  AgentBlueprint AgentBlueprint[]
  AgentClone AgentClone[]
  Business Business[]
  derivativecontractDerivativecontractBuyeridtouser DerivativeContract[]   @relation("DerivativeContract_buyerIdToUser")
  derivativecontractDerivativecontractSelleridtouser DerivativeContract[]   @relation("DerivativeContract_sellerIdToUser")
  Notification Notification[]
  Position Position[]
  Recommendation Recommendation[]
  transactionTransactionTouseridtouser Transaction[]          @relation("Transaction_toUserIdToUser")
  transactionTransactionFromuseridtouser Transaction[]          @relation("Transaction_fromUserIdToUser")
  UserConnection UserConnection[]
  investmentProposals investment_proposals[]
  investments investments[]
  nodes nodes[]
  platformConnections platform_connections[]
  proposals proposals[]
  rewards rewards[]
  stakes stakes[]
  startups startups[]
  tokenTransactionsTokenTransactionsToUserIdtouser token_transactions[]   @relation("token_transactions_to_user_idToUser")
  tokenTransactionsTokenTransactionsFromUserIdtouser token_transactions[]   @relation("token_transactions_from_user_idToUser")
  votes votes[]

  @@index([reputationScore])
  @@index([email])
  capabilities Json?
}
  capabilities Json?
}

model Userconnection {
  @@map("UserConnection")
  id String                @id @default(cuid())
  userId String
  @id @default(cuid())connectorId         String
  @id @default(cuid())credentials         Json?
  status String                @default("active")
  lastUsed DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtAgentServiceBinding AgentServiceBinding[]
  IntegrationLog IntegrationLog[]
  Connector Connector             @relation(fields: [connectorId], references: [id])
  User User                  @relation(fields: [userId], references: [id])

  @@unique([userId, connectorId])
  capabilities Json?
}
  capabilities Json?
}

model Deployment {
  @@map("Deployment")
  id String               @id @default(cuid())
  agentId String
  @id @default(cuid())platformId          String
  @id @default(cuid())externalId           String?
  config Json?
  status String               @default("pending")
  revenue Float                @default(0)
  lastPing DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtplatformConnections platform_connections @relation(fields: [platform_id], references: [id])
  Agent Agent                @relation(fields: [agent_id], references: [id])
  revenueLogs revenue_logs[]
  capabilities Json?
}
  capabilities Json?
}

model Duediligencereport {
  @@map("due_diligencereport")
  id String               @id @default(cuid())
  proposalId String
  @id @default(cuid())agentId             String?
  score Float
  summary String
  details Json?
  risks Json?
  recommendation String
  createdAt DateTime             @default(now())
  Agent Agent?               @relation(fields: [agent_id], references: [id])
  investmentProposals investment_proposals @relation(fields: [proposal_id], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Investmentproposal {
  @@map("investmentproposal")
  id String                  @id @default(cuid())
  startupId String
  @id @default(cuid())proposerId           String
  @id @default(cuid())title                 String
  description String
  askAmount Float
  equity Float?
  status String                  @default("pending")
  createdAt DateTime                @default(now())
  reviewedAt DateTime?
  fundedAt DateTime?
  dueDiligenceReports due_diligence_reports[]
  User User                    @relation(fields: [proposer_id], references: [id])
  startups startups                @relation(fields: [startup_id], references: [id])
  investments investments[]
  capabilities Json?
}
  capabilities Json?
}

model Investment {
  @@map("investments")
  id String               @id @default(cuid())
  proposalId String
  @id @default(cuid())investorId          String
  @id @default(cuid())amount               Float
  equity Float?
  tokenValue Float?
  status String               @default("active")
  createdAt DateTime             @default(now())
  exitedAt DateTime?
  returnAmount Float?
  User User                 @relation(fields: [investor_id], references: [id])
  investmentProposals investment_proposals @relation(fields: [proposal_id], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Nodereward {
  @@map("nodereward")
  id String   @id @default(cuid())
  nodeId String
  @id @default(cuid())amount       Float
  reason String
  periodStart DateTime
  periodEnd DateTime
  paid Boolean  @default(false)
  createdAt DateTime @default(now())
  nodes nodes    @relation(fields: [node_id], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Nodetask {
  @@map("nodetask")
  id String    @id @default(cuid())
  nodeId String
  @id @default(cuid())agentId     String?
  type String
  payload Json?
  status String    @default("pending")
  result Json?
  startedAt DateTime?
  completedAt DateTime?
  reward Float?
  createdAt DateTime  @default(now())
  Agent Agent?    @relation(fields: [agent_id], references: [id])
  nodes nodes     @relation(fields: [node_id], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Node {
  @@map("nodes")
  id String         @id @default(cuid())
  ownerId String
  @id @default(cuid())name         String
  endpoint String?
  status String         @default("offline")
  version String?
  lastPing DateTime?
  totalEarned Float          @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtnodeRewards node_rewards[]
  nodeTasks node_tasks[]
  User User           @relation(fields: [owner_id], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Platformconnection {
  @@map("platformconnection")
  id String        @id @default(cuid())
  userId String
  @id @default(cuid())platform    String
  credentials Json
  status String        @default("active")
  lastUsed DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtdeployments deployments[]
  User User          @relation(fields: [user_id], references: [id])

  @@unique([user_id, platform])
  capabilities Json?
}
  capabilities Json?
}

model Proposal {
  @@map("proposals")
  id String               @id @default(cuid())
  title String
  description String
  proposerId String
  @id @default(cuid())status             String               @default("active")
  votingStarts DateTime             @default(now())
  votingEnds DateTime
  createdAt DateTime             @default(now())
  executedAt DateTime?
  User User                 @relation(fields: [proposer_id], references: [id])
  tokenTransactions token_transactions[]
  votes votes[]
  capabilities Json?
}
  capabilities Json?
}

model Revenuelog {
  @@map("revenuelog")
  id String      @id @default(cuid())
  deploymentId String
  @id @default(cuid())amount        Float
  currency String      @default("USD")
  description String?
  recordedAt DateTime    @default(now())
  settled Boolean     @default(false)
  deployments deployments @relation(fields: [deployment_id], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Reward {
  @@map("rewards")
  id String    @id @default(cuid())
  userId String
  @id @default(cuid())amount      Float
  reason String
  referenceId String?
  claimed Boolean   @default(false)
  createdAt DateTime  @default(now())
  claimedAt DateTime?
  User User      @relation(fields: [user_id], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Stake {
  @@map("stakes")
  id String    @id @default(cuid())
  stakerId String
  @id @default(cuid())agentId    String?
  amount Float
  status String    @default("active")
  lockUntil DateTime?
  createdAt DateTime  @default(now())
  unstakedAt DateTime?
  Agent Agent?    @relation(fields: [agent_id], references: [id])
  User User      @relation(fields: [staker_id], references: [id])

  @@unique([staker_id, agent_id])
  capabilities Json?
}
  capabilities Json?
}

model Startup {
  @@map("startups")
  id String                 @id @default(cuid())
  name String
  description String
  founderId String
  @id @default(cuid())website              String?
  stage String
  tokenAmount Float                  @default(0)
  valuation Float?
  status String                 @default("pending")
  createdAt DateTime               @default(now())
  updatedAt DateTime @updatedAt
  @updatedAtinvestmentProposals investment_proposals[]
  User User                   @relation(fields: [founder_id], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Tokentransaction {
  @@map("tokentransaction")
  id String     @id @default(cuid())
  fromUserId String?
  toUserId String?
  amount Float
  type String
  referenceId String?
  createdAt DateTime   @default(now())
  proposalId String?
  proposals proposals? @relation(fields: [proposalId], references: [id])
  userTokenTransactionsToUserIdtouser User?      @relation("token_transactions_to_user_idToUser", fields: [to_user_id], references: [id])
  userTokenTransactionsFromUserIdtouser User?      @relation("token_transactions_from_user_idToUser", fields: [from_user_id], references: [id])
  capabilities Json?
}
  capabilities Json?
}

model Vote {
  @@map("votes")
  id String    @id @default(cuid())
  proposalId String
  @id @default(cuid())voterId    String
  @id @default(cuid())support     Boolean
  weight Float
  createdAt DateTime  @default(now())
  User User      @relation(fields: [voter_id], references: [id])
  proposals proposals @relation(fields: [proposal_id], references: [id])

  @@unique([proposal_id, voter_id])
  capabilities Json?
}
  capabilities Json?
}

model Unknownmodel {
  @@map("UnknownModel")
  id String   @id @default(cuid()) @default(cuid())
  name String
  description String
  agentType String
  configuration Json    // the agent's configuration (prompts, skills, etc.)
  price Float     // price in $AGENT to purchase this blueprint
  royaltyRate Float     // percentage (0-100) of franchise revenue paid to blueprint creator
  status String    @default("active") // active, inactive
  creatorId String    @id @default(cuid())@map("creator_id") // user who created the blueprint
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  creator User      @relation(fields: [creatorId], references: [id])
  franchises Franchise[]

  @@map("agent_blueprints")
  capabilities Json?
}
  capabilities Json?
}

model Franchise {
  @@map("Franchise")
  id String   @id @default(cuid()) @default(cuid())
  blueprintId String   @id @default(cuid())@map("blueprint_id")
  ownerId String   @id @default(cuid())@map("owner_id") // user who bought the franchise
  agentId String?  @map("agent_id") // the actual agent created from this blueprint (optional)
  status String   @default("active") // active, paused, terminated
  purchasePrice Float   // price paid at purchase
  totalRoyaltyPaid Float @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  blueprint AgentBlueprint @relation(fields: [blueprintId], references: [id])
  owner User           @relation(fields: [ownerId], references: [id])
  agent Agent?         @relation(fields: [agentId], references: [id])
  royaltyPayments RoyaltyPayment[]

  @@map("franchises")
  capabilities Json?
}
  capabilities Json?
}

model Royaltypayment {
  @@map("RoyaltyPayment")
  id String   @id @default(cuid()) @default(cuid())
  franchiseId String   @id @default(cuid())@map("franchise_id")
  amount Float
  periodStart DateTime @map("period_start")
  periodEnd DateTime @map("period_end")
  status String   @default("pending") // pending, paid
  paidAt DateTime? @map("paid_at")
  createdAt DateTime @default(now()) @map("created_at")

  franchise Franchise @relation(fields: [franchiseId], references: [id])

  @@map("royalty_payments")
  capabilities Json?
}
  capabilities Json?
}

model Unknownmodel {
  @@map("UnknownModel")
  id String   @id @default(cuid()) @default(cuid())
  blueprintId String   @id @default(cuid())@map("blueprint_id")
  ownerId String   @id @default(cuid())@map("owner_id")
  agentId String?  @map("agent_id")
  status String   @default("active")
  purchasePrice Float
  totalRoyaltyPaid Float @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  blueprint AgentBlueprint @relation(fields: [blueprintId], references: [id])
  owner User           @relation(fields: [ownerId], references: [id])
  agent Agent?         @relation(fields: [agentId], references: [id])
  royaltyPayments RoyaltyPayment[]

  @@map("franchises")
  capabilities Json?
}
  capabilities Json?
}

model Unknownmodel {
  @@map("UnknownModel")
  id String   @id @default(cuid()) @default(cuid())
  franchiseId String   @id @default(cuid())@map("franchise_id")
  amount Float
  periodStart DateTime @map("period_start")
  periodEnd DateTime @map("period_end")
  status String   @default("pending")
  paidAt DateTime? @map("paid_at")
  createdAt DateTime @default(now()) @map("created_at")

  franchise Franchise @relation(fields: [franchiseId], references: [id])

  @@map("royalty_payments")
  capabilities Json?
}
  capabilities Json?
}


model Nation {
  @@map("Nation")
  id String   @id @default(cuid()) @default(cuid())
  name String   @unique
  description String
  founderId String   @id @default(cuid())@map("founder_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  treasury Float    @default(0) // $AGENT held by the nation

  founder User     @relation(fields: [founderId], references: [id])
  citizens Citizen[]
  proposals NationProposal[]

  @@map("nations")
  capabilities Json?
}
  capabilities Json?
}

model Citizen {
  @@map("Citizen")
  id String   @id @default(cuid()) @default(cuid())
  userId String   @id @default(cuid())@map("user_id")
  nationId String   @id @default(cuid())@map("nation_id")
  role String   @default("citizen") // "founder", "citizen", "minister"
  joinedAt DateTime @default(now()) @map("joined_at")

  user User     @relation(fields: [userId], references: [id])
  nation Nation   @relation(fields: [nationId], references: [id])

  @@unique([userId, nationId])
  @@map("citizens")
  capabilities Json?
}
  capabilities Json?
}

model Nationproposal {
  @@map("NationProposal")
  id String   @id @default(cuid()) @default(cuid())
  nationId String   @id @default(cuid())@map("nation_id")
  title String
  description String
  proposerId String   @id @default(cuid())@map("proposer_id")
  status String   @default("active") // active, passed, rejected, executed
  votingStarts DateTime @default(now()) @map("voting_starts")
  votingEnds DateTime @map("voting_ends")
  executedAt DateTime? @map("executed_at")
  createdAt DateTime @default(now()) @map("created_at")

  nation Nation   @relation(fields: [nationId], references: [id])
  proposer User     @relation(fields: [proposerId], references: [id])
  votes NationVote[]
  transactions TokenTransaction[] // if proposal involves treasury spending

  @@map("nation_proposals")
  capabilities Json?
}
  capabilities Json?
}

model Nationvote {
  @@map("NationVote")
  id String   @id @default(cuid()) @default(cuid())
  proposalId String   @id @default(cuid())@map("proposal_id")
  voterId String   @id @default(cuid())@map("voter_id")
  support Boolean
  weight Float    // based on staked tokens or citizenship duration
  createdAt DateTime @default(now()) @map("created_at")

  proposal NationProposal @relation(fields: [proposalId], references: [id])
  voter User           @relation(fields: [voterId], references: [id])

  @@unique([proposalId, voterId])
  @@map("nation_votes")
  capabilities Json?
}
  capabilities Json?
}

model Deploymentlog {
  @@map("DeploymentLog")
  id String   @id @default(cuid()) @default(cuid())
  deploymentId String  @id @default(cuid())@map("deployment_id")
  level String   // "info", "warn", "error"
  message String
  metadata Json?
  timestamp DateTime @default(now()) @map("timestamp")

  deployment Deployment @relation(fields: [deploymentId], references: [id])

  @@map("deployment_logs")
  capabilities Json?
}
  capabilities Json?
}
// A2AP Messages
model Agentmessage {
  @@map("AgentMessage")
  id String   @id @default(cuid()) @default(cuid())
  fromAgentId String   @id @default(cuid())@map("from_agent_id")
  toAgentId String   @id @default(cuid())@map("to_agent_id")
  content Json
  signature String   // quantum‑resistant signature
  status String   @default("pending") // pending, delivered, failed
  createdAt DateTime @default(now()) @map("created_at")
  deliveredAt DateTime? @map("delivered_at")

  fromAgent Agent    @relation("MessagesFrom", fields: [fromAgentId], references: [id])
  toAgent Agent    @relation("MessagesTo", fields: [toAgentId], references: [id])

  @@map("agent_messages")
  capabilities Json?
}
  capabilities Json?
}

// Consensus rounds
model Consensusround {
  @@map("ConsensusRound")
  id String   @id @default(cuid()) @default(cuid())
  roundNumber Int      @unique
  topic String   // e.g., "work_verification", "agent_task"
  data Json?    // data to be agreed upon
  status String   @default("voting") // voting, accepted, rejected
  createdAt DateTime @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")
  result Json?    // final agreed result

  votes ConsensusVote[]

  @@map("consensus_rounds")
  capabilities Json?
}
  capabilities Json?
}

model Consensusvote {
  @@map("ConsensusVote")
  id String   @id @default(cuid()) @default(cuid())
  roundId String   @id @default(cuid())@map("round_id")
  voterId String   @id @default(cuid())@map("voter_id") // agent or node ID
  vote Boolean  // true = accept, false = reject
  weight Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  round ConsensusRound @relation(fields: [roundId], references: [id])
  voter Agent          @relation(fields: [voterId], references: [id]) // could also be Node

  @@map("consensus_votes")
  capabilities Json?
}
  capabilities Json?
}

// Quantum‑resistant keys (simplified)
model Quantumkey {
  @@map("QuantumKey")
  id String   @id @default(cuid()) @default(cuid())
  agentId String   @id @default(cuid())@map("agent_id") @unique
  publicKey String   // stored as base64
  privateKey String   // encrypted (or not stored)
  algorithm String   @default("kyber512") // kyber, sphincs, etc.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agent Agent    @relation(fields: [agentId], references: [id])

  @@map("quantum_keys")
  capabilities Json?
}
  capabilities Json?
}

