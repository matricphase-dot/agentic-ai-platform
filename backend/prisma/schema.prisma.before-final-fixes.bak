generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model users {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String?
  avatar           String?
  balance          Float    @default(0)
  reputationScore  Int      @default(1000)
  role             String   @default("user")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  agents      agents[]
  stakes      stakes[]
  votes       votes[]
  teams       teams[]
  proposals   proposals[]
  reviews     reviews[]
  recordings  recordings[]
  nodes       nodes[]
  node_tasks  node_tasks[]
  settings    UserSettings?
}

model agents {
  id                String   @id @default(cuid())
  name              String
  description       String?
  agentType         String
  status            String   @default("inactive")
  reputationScore   Int      @default(1000)
  hourlyRate        Float    @default(50)
  successRate       Float    @default(0.85)
  totalValueCreated Float    @default(0)
  totalEarnings     Float    @default(0)
  revenueShare      Float?   @default(0)
  configuration     Json?
  tasksCompleted    Int      @default(0)
  specialties       String[]
  ownerId           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  capabilities      String?
  system_prompt     String?
  model_provider    String?  @default("ollama-local")
  model_name        String?  @default("llama2")

  owner        users         @relation(fields: [ownerId], references: [id])
  stakes       stakes[]
  team_agents  team_agents[]
  node_tasks   node_tasks[]
  templates    templates[]
  reviews      reviews[]
  messages_sent      messages[] @relation("messages_senderIdToagents")
  messages_received  messages[] @relation("messages_receiverIdToagents")
}

model UserSettings {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         users    @relation(fields: [userId], references: [id])
  primaryColor String?
  logoUrl      String?
  theme        String?  @default("light")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@map("user_settings")
}

model stakes {
  id              String   @id @default(cuid())
  amount          Float
  sharePercentage Float
  stakerId        String
  agentId         String
  totalReturns    Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  staker users  @relation(fields: [stakerId], references: [id])
  agent  agents @relation(fields: [agentId], references: [id])

  @@unique([stakerId, agentId])
}

model votes {
  id         String   @id @default(cuid())
  proposalId String
  userId     String
  option     String
  weight     Float
  createdAt  DateTime @default(now())

  proposal proposals @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     users     @relation(fields: [userId], references: [id])

  @@unique([proposalId, userId])
}

model proposals {
  id          String   @id @default(cuid())
  title       String
  description String
  options     Json
  endDate     DateTime
  createdById String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator users @relation(fields: [createdById], references: [id])
  votes   votes[]
}

model reviews {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?
  userId     String
  templateId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     users     @relation(fields: [userId], references: [id])
  template templates @relation(fields: [templateId], references: [id])
  agents   agents?   @relation(fields: [agentsId], references: [id])
  agentsId String?

  @@unique([userId, templateId])
}

model templates {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  price       Float
  unit        String
  status      String   @default("active")
  agentId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent   agents    @relation(fields: [agentId], references: [id])
  reviews reviews[]
}

model recordings {
  id         String   @id @default(cuid())
  userId     String
  filename   String
  filepath   String
  duration   Int?
  transcript String?
  analysis   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model nodes {
  id         String    @id @default(cuid())
  ownerId    String
  name       String
  endpoint   String?
  status     String    @default("offline")
  lastPing   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  specs      Json?     // CPU, RAM, GPU, etc.
  location   String?
  version    String?

  owner        users          @relation(fields: [ownerId], references: [id])
  node_tasks   node_tasks[]
  node_rewards node_rewards[]
}

model node_tasks {
  id          String    @id @default(cuid())
  nodeId      String
  agentId     String
  userId      String
  type        String
  input       Json?
  output      Json?
  status      String    @default("pending")
  startedAt   DateTime?
  completedAt DateTime?
  reward      Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  node  nodes  @relation(fields: [nodeId], references: [id])
  agent agents @relation(fields: [agentId], references: [id])
  user  users  @relation(fields: [userId], references: [id])
}

model node_rewards {
  id         String   @id @default(cuid())
  nodeId     String
  amount     Float
  reason     String?
  createdAt  DateTime @default(now())
  taskId     String?
  task       node_tasks? @relation(fields: [taskId], references: [id])

  node nodes @relation(fields: [nodeId], references: [id])
}

model team_agents {
  id        String   @id @default(cuid())
  teamId    String
  agentId   String
  createdAt DateTime @default(now())

  team  teams  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  agent agents @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([teamId, agentId])
}

model teams {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        users         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team_agents team_agents[]

  @@unique([name, userId])
}

model messages {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  content     String
  status      String   @default("sent")
  createdAt   DateTime @default(now())
  deliveredAt DateTime?

  sender   agents @relation("messages_senderIdToagents", fields: [senderId], references: [id], onDelete: Cascade)
  receiver agents @relation("messages_receiverIdToagents", fields: [receiverId], references: [id], onDelete: Cascade)
}

enum AgentStatus {
  IDLE
  WORKING
  TRAINING
  MAINTENANCE
  TERMINATED
}

enum AgentType {
  MARKETING
  CODING
  RESEARCH
  SALES
  SUPPORT
  ANALYTICS
  NEGOTIATION
  CREATIVE
  CUSTOM
}

enum BusinessStatus {
  ACTIVE
  PAUSED
  SCALING
  TERMINATED
}

enum BusinessType {
  ECOMMERCE
  SAAS
  AGENCY
  CONTENT
  CONSULTING
  MARKETPLACE
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  TERMINATED
  DISPUTED
}

enum NotificationType {
  AGENT_COMPLETED_TASK
  BUSINESS_REVENUE
  STAKE_PAYOUT
  SYSTEM_ALERT
  MARKET_UPDATE
}

enum Role {
  users
  ADMIN
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  AGENT_PAYMENT
  STAKE_PURCHASE
  DIVIDEND_PAYOUT
  BUSINESS_REVENUE
  WITHDRAWAL
  DEPOSIT
  REFERRAL_BONUS
}